{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--host", "0.0.0.0", "--port", "8888"],
      "cwd": "${workspaceFolder}/server-agent",
      "python": "${workspaceFolder}/server-agent/.venv/Scripts/python.exe"
    },
    {
      "name": "Frontend: Electron (Dev)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/client-electron",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"]
    },
    {
      "name": "Full System (Launch All)",
      "type": "node",
      "request": "launch"
    }
  ]
}
